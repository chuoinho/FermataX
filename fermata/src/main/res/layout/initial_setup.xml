<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/initial_setup"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/initial_setup_subtitle"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/initial_setup_nav_position"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/initial_setup_nav_position"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/initial_setup_nav_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/initial_setup_left"
                android:textColor="?android:attr/textColorPrimary" />

            <RadioButton
                android:id="@+id/initial_setup_nav_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="@string/initial_setup_right"
                android:textColor="?android:attr/textColorPrimary" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/initial_setup_app_language"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/initial_setup_app_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/initial_setup_voice_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/initial_setup_voice_enabled"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/initial_setup_voice_language_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/initial_setup_voice_language"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/initial_setup_voice_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/initial_setup_microphone_test"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/initial_setup_test_microphone" />

        <TextView
            android:id="@+id/initial_setup_microphone_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <Button
            android:id="@+id/initial_setup_continue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/initial_setup_continue" />
    </LinearLayout>
</ScrollView>
