<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2E7AA7FF" />
            <stroke android:width="1dp" android:color="#527AA7FF" />
            <corners android:radius="13dp" />
        </shape>
    </item>
    <item android:gravity="right" android:width="3dp" android:top="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#7AA7FF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
