<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/rippleColor">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="0" android:startColor="#F2141F2D" android:endColor="#EB080B11" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="315" android:startColor="#2A7AA7FF" android:endColor="#007AA7FF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#857AA7FF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
